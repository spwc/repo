<?xml version='1.0' encoding='utf-8'?>
<addons><addon id="plugin.program.sptoolbox" name="TOOLBOX" version="1.0.3" provider-name="SEAN-PAUL">
	<requires>
		<import addon="xbmc.python" version="3.0.0" />
		<import addon="script.module.requests" optional="true" />
	</requires>
	<extension point="xbmc.python.pluginsource" library="addon.py">
		<provides>executable</provides>
	</extension>
	<extension point="xbmc.service" library="service.py" />
	<extension point="xbmc.addon.metadata">
		<summary lang="en_GB">This toolbox will update your kodi layout, settings and addons.</summary>
		<description lang="en_GB">Kodi Toolbox</description>
		<disclaimer lang="en_GB">Use at your own discretion.</disclaimer>
		<language>en</language>
		<platform>all</platform>
		<license>GPL-2.0-or-later</license>
		<forum />
		<website /> 
		<email />
		<source />
		<news>1.0.3 - UPDATED -
* Set TOOLBOX to save Real Debrid and Trakt by default
* Snazzed up some words here and there
		</news>
		<assets>
				<icon>resources/icon.png</icon>
				<fanart>resources/fanart.jpg</fanart>
				<banner />
				<clearlogo />
				<screenshot />
		</assets>
	</extension>
</addon><addon id="repository.spwc" name="Sean-Pauls Repository" version="1.0" provider-name="Sean-Paul">
    <extension point="xbmc.addon.repository" name="Sean-Pauls Repository">
        <dir>
            <info compressed="false">https://raw.githubusercontent.com/spwc/repo/master/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/spwc/repo/master/addons.xml.md5</checksum>
            <datadir zip="true">https://raw.githubusercontent.com/spwc/repo/master/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>Sean-Pauls Repository</summary>
        <description>Use at your ownn descretion</description>
        <disclaimer>Addons to update Kodi</disclaimer>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon></addons>